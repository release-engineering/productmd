FROM fedora:41 AS certs

RUN dnf install -y --setopt=install_weak_deps=False openssl && dnf clean all
RUN set -e && \
    openssl req -x509 -newkey rsa:4096 -nodes -sha256 \
      -keyout /ca.key -out /ca.crt -days 36500 \
      -subj '/CN=productmd-test-ca' 2>/dev/null && \
    openssl req -newkey rsa:4096 -nodes -sha256 \
      -keyout /server.key -out /tmp/server.csr \
      -subj '/CN=registry' 2>/dev/null && \
    printf 'subjectAltName=DNS:registry,DNS:localhost' > /tmp/san.cnf && \
    openssl x509 -req -in /tmp/server.csr -CA /ca.crt -CAkey /ca.key \
      -CAcreateserial -out /server.crt -days 36500 -sha256 \
      -extfile /tmp/san.cnf 2>/dev/null

FROM registry:2

COPY --from=certs /server.crt /certs/server.crt
COPY --from=certs /server.key /certs/server.key
COPY --from=certs /ca.crt /certs/ca.crt

ENV REGISTRY_HTTP_TLS_CERTIFICATE=/certs/server.crt
ENV REGISTRY_HTTP_TLS_KEY=/certs/server.key
